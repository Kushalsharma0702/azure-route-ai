# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/routeaura

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-change-in-production-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / LLM ───────────────────────────────────────────────
USE_LLM=true
LLM_PRIMARY_PROVIDER=mistral
MISTRAL_API_KEY=UDl9Bde5hvBEk8KBcARUIbj8MoyxSVn2
MISTRAL_MODEL=mistral-small-latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

# ── Voice / TTS / STT ──────────────────────────────────────
SARVAM_API_KEY=sk_lzomvfh4_qe9eLsNL9EiuADEjFfU9Ta1s
DEFAULT_SARVAM_SPEAKER=meera

# ── App Settings ────────────────────────────────────────────
APP_NAME=RouteAura
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8080,http://localhost:8081,http://localhost:8082
LOG_LEVEL=INFO
