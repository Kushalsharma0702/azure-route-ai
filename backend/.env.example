# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/routeaura

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / LLM ───────────────────────────────────────────────
USE_LLM=true
LLM_PRIMARY_PROVIDER=mistral
MISTRAL_API_KEY=your_mistral_key_here
MISTRAL_MODEL=mistral-small-latest
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

# ── Voice / TTS / STT ──────────────────────────────────────
SARVAM_API_KEY=your_sarvam_key_here
DEFAULT_SARVAM_SPEAKER=meera

# ── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── External APIs ───────────────────────────────────────────
AVIATIONSTACK_API_KEY=your_aviationstack_key
AMADEUS_API_KEY=your_amadeus_key
AMADEUS_API_SECRET=your_amadeus_secret
RAILAPI_KEY=your_railapi_key

# ── App Settings ────────────────────────────────────────────
APP_NAME=RouteAura
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
